<?php
/**
 * Order confirmation page.
 *
 * Reads the just-placed order from the checkout session and renders a
 * thank-you panel with the order number, the customer email Magento sent
 * the confirmation to, and the grand total. The new-order email is
 * dispatched by Magento's standard sales_order_place_after observer; we
 * don't trigger it from here.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */
declare(strict_types=1);

/** @var \Magento\Checkout\Model\Session $checkoutSession */
$checkoutSession = $block->getData('checkoutSession')
    ?? \Magento\Framework\App\ObjectManager::getInstance()
        ->get(\Magento\Checkout\Model\Session::class);

/** @var \Magento\Framework\Pricing\PriceCurrencyInterface $priceCurrency */
$priceCurrency = \Magento\Framework\App\ObjectManager::getInstance()
    ->get(\Magento\Framework\Pricing\PriceCurrencyInterface::class);

$lastOrder   = $checkoutSession->getLastRealOrder();
$incrementId = $lastOrder && $lastOrder->getId() ? $lastOrder->getIncrementId() : null;
$email       = $lastOrder && $lastOrder->getId() ? (string) $lastOrder->getCustomerEmail() : '';
$grandTotal  = $lastOrder && $lastOrder->getId()
    ? $priceCurrency->format((float) $lastOrder->getGrandTotal(), false)
    : '';
?>

<div class="checkout-confirmation">

    <div class="checkout-confirmation-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none"
             viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
    </div>

    <h1 class="checkout-confirmation-title">
        <?= $escaper->escapeHtml(__('Thank you for your order!')) ?>
    </h1>

    <?php if ($incrementId): ?>
    <p class="checkout-confirmation-lead">
        <?= $escaper->escapeHtml(__('Your order number is')) ?>
        <strong>#<?= $escaper->escapeHtml($incrementId) ?></strong>
    </p>
    <?php endif ?>

    <?php if ($email !== '' || $grandTotal !== ''): ?>
    <dl class="checkout-confirmation-meta">
        <?php if ($email !== ''): ?>
        <div>
            <dt><?= $escaper->escapeHtml(__('Confirmation sent to')) ?></dt>
            <dd><?= $escaper->escapeHtml($email) ?></dd>
        </div>
        <?php endif ?>
        <?php if ($grandTotal !== ''): ?>
        <div>
            <dt><?= $escaper->escapeHtml(__('Total paid')) ?></dt>
            <dd><?= $escaper->escapeHtml($grandTotal) ?></dd>
        </div>
        <?php endif ?>
    </dl>
    <?php endif ?>

    <p class="checkout-confirmation-note">
        <?= $escaper->escapeHtml(__('We\'ll email you again as soon as your order ships.')) ?>
    </p>

    <div class="checkout-confirmation-actions">
        <a href="<?= $escaper->escapeUrl($block->getUrl('sales/order/history')) ?>"
           class="checkout-btn">
            <?= $escaper->escapeHtml(__('View my orders')) ?>
        </a>
        <a href="<?= $escaper->escapeUrl($block->getUrl()) ?>"
           class="checkout-btn checkout-btn-secondary">
            <?= $escaper->escapeHtml(__('Continue shopping')) ?>
        </a>
    </div>

</div>
