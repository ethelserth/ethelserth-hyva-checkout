<?php
/**
 * Order confirmation page.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */
declare(strict_types=1);

/** @var \Magento\Checkout\Model\Session $checkoutSession */
$checkoutSession = $block->getData('checkoutSession')
    ?? \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\Checkout\Model\Session::class);

$lastOrder = $checkoutSession->getLastRealOrder();
$incrementId = $lastOrder ? $lastOrder->getIncrementId() : null;
?>

<div class="max-w-2xl mx-auto px-4 py-16 text-center">

    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-3">
        <?= $escaper->escapeHtml(__('Thank you for your order!')) ?>
    </h1>

    <?php if ($incrementId): ?>
    <p class="text-gray-600 text-lg mb-6">
        <?= $escaper->escapeHtml(__('Your order number is:')) ?>
        <strong class="text-gray-900">#<?= $escaper->escapeHtml($incrementId) ?></strong>
    </p>
    <?php endif ?>

    <p class="text-gray-500 mb-8">
        <?= $escaper->escapeHtml(__('A confirmation email has been sent to you. We\'ll notify you when your order ships.')) ?>
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="<?= $escaper->escapeUrl($block->getUrl('sales/order/history')) ?>"
           class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors">
            <?= $escaper->escapeHtml(__('View my orders')) ?>
        </a>
        <a href="<?= $escaper->escapeUrl($block->getUrl()) ?>"
           class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors">
            <?= $escaper->escapeHtml(__('Continue shopping')) ?>
        </a>
    </div>

</div>
