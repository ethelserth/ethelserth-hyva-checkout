<?php
/**
 * Root checkout template.
 *
 * @var \Ethelserth\Checkout\Block\Checkout $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Hyva\Theme\Model\ViewModelRegistry $viewModels
 */
declare(strict_types=1);

$steps = $block->getSteps();
$stepsJson = $block->getStepsJson();
?>

<?php /* No `defer` here on purpose. Hyvä loads Alpine as `<script type="module" defer>`
        in `<head>`, which runs after DOM parse. This synchronous script in the
        body parses BEFORE Alpine's deferred module executes, so its
        `addEventListener('alpine:init', …)` is registered in time to catch the
        event Alpine fires on init. Adding `defer` here would put both scripts
        in the deferred queue and our listener would register AFTER Alpine
        already dispatched alpine:init — silently breaking the store. */ ?>
<script src="<?= $escaper->escapeUrl($block->getViewFileUrl('Ethelserth_Checkout::js/checkout/store.js')) ?>"></script>

<div
    id="checkout-main"
    x-data
    x-init="$store.checkout.setup(<?= $escaper->escapeHtmlAttr($stepsJson) ?>)"
    class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6"
    @address-saved.window="$store.checkout.advance('address', 'shipping')"
    @shipping-method-selected.window="$store.checkout.advance('shipping', 'payment')"
    @step-edit-requested.window="$store.checkout.reopenStep($event.detail[0] ?? $event.detail)"
    @order-placed.window="window.location.href = '/checkout/success'"
    @checkout-session-expired.window="window.alert($event.detail.message ?? 'Your checkout session has expired.'); window.location.href = '/checkout/cart'"
>

    <div class="flex flex-col lg:grid lg:grid-cols-12 lg:gap-x-12 xl:gap-x-16">

        <!-- Left: express rail + step sections.
             On mobile this is rendered AFTER the summary (order-2) so the
             collapsed mobile summary bar sticks to the top of the viewport. -->
        <div class="order-2 lg:order-1 lg:col-span-7">

            <h1 class="checkout-title"><?= $escaper->escapeHtml(__('Checkout')) ?></h1>

            <!-- Express rail: populated by PSP modules (Revolut Fast Checkout, etc.) -->
            <?= $block->getChildHtml('checkout.express.rail') ?>

            <?php foreach ($steps as $step): ?>
            <?php $stepName = $escaper->escapeHtml($step->getName()); ?>
            <?php $stepLabel = $escaper->escapeHtml($step->getLabel()); ?>
            <?php $stepOrder = (int)($step->getOrder() / 10); ?>

            <div
                id="checkout-step-<?= $stepName ?>"
                class="checkout-section mb-3"
                :class="{
                    'is-active': $store.checkout.isActive('<?= $stepName ?>'),
                    'is-done':   $store.checkout.isDone('<?= $stepName ?>'),
                    'is-locked': $store.checkout.isLocked('<?= $stepName ?>')
                }"
            >
                <div class="checkout-section-header">
                    <div class="flex items-center gap-3">
                        <span class="checkout-step-badge">
                            <template x-if="$store.checkout.isDone('<?= $stepName ?>')">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </template>
                            <template x-if="!$store.checkout.isDone('<?= $stepName ?>')">
                                <span><?= $stepOrder ?></span>
                            </template>
                        </span>
                        <h2 class="checkout-step-title"><?= $stepLabel ?></h2>
                    </div>

                    <button type="button"
                            x-show="$store.checkout.isDone('<?= $stepName ?>')"
                            x-cloak
                            @click="$store.checkout.reopenStep('<?= $stepName ?>')"
                            class="checkout-edit-btn">
                        <?= $escaper->escapeHtml(__('Edit')) ?>
                    </button>
                </div>

                <?php /* Step body renders whenever the step is active OR done —
                       the step template itself toggles between its "active" view
                       (form / method list) and its collapsed done summary. Locked
                       steps render nothing (their form state is meaningless yet). */ ?>
                <div x-show="$store.checkout.isActive('<?= $stepName ?>') || $store.checkout.isDone('<?= $stepName ?>')"
                     x-cloak
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 -translate-y-1"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     class="checkout-section-body">
                    <?= $block->getChildHtml('checkout.step.' . $step->getName()) ?>
                </div>

            </div>
            <?php endforeach ?>

        </div>

        <!-- Right on desktop / top on mobile: order summary.
             Sticky on both viewports — `top-0` on mobile (under storefront header),
             `top-6` on desktop. -->
        <div class="order-1 lg:order-2 lg:col-span-5 mb-4 lg:mb-0">
            <div class="sticky top-0 z-30 lg:top-6">
                <?= $block->getChildHtml('checkout.summary') ?>
            </div>
        </div>

    </div>

</div>
