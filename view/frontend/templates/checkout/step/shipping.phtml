<?php
/**
 * Shipping step — method list.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */
declare(strict_types=1);
?>

<div>

    <!-- Skeleton while loading -->
    <div wire:loading class="space-y-3">
        <?php for ($i = 0; $i < 3; $i++): ?>
        <div class="animate-pulse flex items-center gap-4 p-4 border border-gray-100 rounded-xl">
            <div class="w-4 h-4 rounded-full bg-gray-200 flex-shrink-0"></div>
            <div class="flex-1 space-y-2">
                <div class="h-4 bg-gray-200 rounded w-1/3"></div>
                <div class="h-3 bg-gray-100 rounded w-1/4"></div>
            </div>
            <div class="h-4 bg-gray-200 rounded w-16"></div>
        </div>
        <?php endfor ?>
    </div>

    <!-- Method list -->
    <div wire:loading.remove class="space-y-2">

        <?php /* Rates are $wire->rates — rendered server-side */ ?>
        <?php if (empty($rates ?? [])): ?>
        <p class="text-gray-500 text-sm py-4">
            <?= $escaper->escapeHtml(__('No shipping methods available. Please verify your address.')) ?>
        </p>
        <?php else: ?>

        <?php foreach (($rates ?? []) as $rate): ?>
        <label class="flex items-center gap-4 p-4 border rounded-xl cursor-pointer transition-colors"
               :class="$wire.selectedCarrier === '<?= $escaper->escapeHtmlAttr($rate['carrier']) ?>' && $wire.selectedMethod === '<?= $escaper->escapeHtmlAttr($rate['method']) ?>'
                   ? 'border-blue-500 bg-blue-50'
                   : 'border-gray-200 hover:border-gray-300 hover:bg-gray-50'">

            <input type="radio"
                   name="shipping_method"
                   value="<?= $escaper->escapeHtmlAttr($rate['carrier'] . '_' . $rate['method']) ?>"
                   wire:click="selectMethod('<?= $escaper->escapeHtmlAttr($rate['carrier']) ?>', '<?= $escaper->escapeHtmlAttr($rate['method']) ?>')"
                   class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500"/>

            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900">
                    <?= $escaper->escapeHtml($rate['carrier_title']) ?>
                </p>
                <p class="text-xs text-gray-500">
                    <?= $escaper->escapeHtml($rate['method_title']) ?>
                </p>
            </div>

            <span class="text-sm font-semibold text-gray-900 flex-shrink-0">
                <?php if ((float)$rate['price'] === 0.0): ?>
                    <span class="text-green-600"><?= $escaper->escapeHtml(__('Free')) ?></span>
                <?php else: ?>
                    €<?= number_format((float)$rate['price'], 2) ?>
                <?php endif ?>
            </span>
        </label>
        <?php endforeach ?>

        <?php endif ?>
    </div>

</div>
