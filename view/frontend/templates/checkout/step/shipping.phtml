<?php
/**
 * Shipping step — root template.
 *
 * One Magewire mount, one root tag. Two logical views inside:
 *   - the method list (visible while the step is active)
 *   - the collapsed summary (visible after shippingMethodSelected fires,
 *     i.e. when the Alpine store flags the step as done)
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Ethelserth\Checkout\Magewire\Step\Shipping $magewire
 */
declare(strict_types=1);

$errorMessage    = $magewire->errorMessage;
$methods         = $magewire->methods;
$selectedCarrier = $magewire->selectedCarrier;
$selectedMethod  = $magewire->selectedMethod;
$summary         = $magewire->getSelectedSummary();
?>

<div>

    <?php if ($errorMessage): ?>
    <div role="alert" class="checkout-error mb-4">
        <?= $escaper->escapeHtml($errorMessage) ?>
    </div>
    <?php endif ?>

    <?php /* Active view — method list. Hidden once step is done. */ ?>
    <div x-show="$store.checkout.isActive('shipping')" x-cloak>

        <div wire:loading class="space-y-3" aria-busy="true" aria-live="polite">
            <?php
            $skeletonTemplate = $block->getTemplateFile('Ethelserth_Checkout::checkout/shipping/skeleton.phtml');
            if ($skeletonTemplate) include $skeletonTemplate;
            ?>
        </div>

        <div wire:loading.remove>

            <?php if (empty($methods)): ?>
            <p class="checkout-hint py-4">
                <?= $escaper->escapeHtml(__('No shipping methods are available for this address. Please verify your delivery details.')) ?>
            </p>
            <?php else: ?>
            <?php
            $methodListTemplate = $block->getTemplateFile('Ethelserth_Checkout::checkout/shipping/method-list.phtml');
            if ($methodListTemplate) include $methodListTemplate;
            ?>
            <?php endif ?>

        </div>

    </div>

    <?php /* Done view — collapsed summary. */ ?>
    <?php if ($summary): ?>
    <div x-show="$store.checkout.isDone('shipping')"
         x-cloak
         class="checkout-done-summary">
        <?php if ($summary['logo_url'] ?? null): ?>
        <img src="<?= $escaper->escapeUrl($summary['logo_url']) ?>"
             alt="<?= $escaper->escapeHtmlAttr($summary['carrier_title']) ?>"
             class="checkout-carrier-logo"
             width="36" height="24"/>
        <?php endif ?>

        <div class="flex-1 min-w-0">
            <p class="checkout-choice-title"><?= $escaper->escapeHtml($summary['method_title']) ?></p>
            <p class="checkout-choice-sub"><?= $escaper->escapeHtml($summary['carrier_title']) ?></p>
        </div>

        <span class="checkout-option-price flex-shrink-0">
            <?= $escaper->escapeHtml($summary['price_formatted']) ?>
        </span>
    </div>
    <?php endif ?>

</div>
