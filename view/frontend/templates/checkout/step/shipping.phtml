<?php
/**
 * Shipping step — method list.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */
declare(strict_types=1);
?>

<div>

    <div wire:loading class="space-y-3">
        <?php for ($i = 0; $i < 3; $i++): ?>
        <div class="animate-pulse checkout-option">
            <div class="w-4 h-4 rounded-full bg-gray-200 flex-shrink-0"></div>
            <div class="flex-1 space-y-2">
                <div class="h-4 bg-gray-200 rounded w-1/3"></div>
                <div class="h-3 bg-gray-100 rounded w-1/4"></div>
            </div>
            <div class="h-4 bg-gray-200 rounded w-16"></div>
        </div>
        <?php endfor ?>
    </div>

    <div wire:loading.remove class="space-y-2">

        <?php if (empty($rates ?? [])): ?>
        <p class="checkout-hint py-4">
            <?= $escaper->escapeHtml(__('No shipping methods available. Please verify your address.')) ?>
        </p>
        <?php else: ?>

        <?php foreach (($rates ?? []) as $rate): ?>
        <label class="checkout-option"
               :class="$wire.selectedCarrier === '<?= $escaper->escapeHtmlAttr($rate['carrier']) ?>' && $wire.selectedMethod === '<?= $escaper->escapeHtmlAttr($rate['method']) ?>' ? 'is-selected' : ''">

            <input type="radio"
                   name="shipping_method"
                   value="<?= $escaper->escapeHtmlAttr($rate['carrier'] . '_' . $rate['method']) ?>"
                   wire:click="selectMethod('<?= $escaper->escapeHtmlAttr($rate['carrier']) ?>', '<?= $escaper->escapeHtmlAttr($rate['method']) ?>')"
                   class="w-4 h-4"/>

            <div class="flex-1 min-w-0">
                <p class="checkout-choice-title">
                    <?= $escaper->escapeHtml($rate['carrier_title']) ?>
                </p>
                <p class="checkout-choice-sub">
                    <?= $escaper->escapeHtml($rate['method_title']) ?>
                </p>
            </div>

            <span class="checkout-option-price flex-shrink-0">
                <?php if ((float)$rate['price'] === 0.0): ?>
                    <?= $escaper->escapeHtml(__('Free')) ?>
                <?php else: ?>
                    €<?= number_format((float)$rate['price'], 2) ?>
                <?php endif ?>
            </span>
        </label>
        <?php endforeach ?>

        <?php endif ?>
    </div>

</div>
