<?php
/**
 * Address step — root template.
 *
 * Magewire injects only $magewire — it does NOT extract public properties
 * as flat PHP variables. We pull everything we need explicitly so that
 * sub-templates included via PHP include() share this scope.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Ethelserth\Checkout\Magewire\Step\Address $magewire
 */
declare(strict_types=1);

/** @var \Ethelserth\Checkout\Model\Address\FieldConfig $fieldConfig */
$fieldConfig = $block->getData('field_config');

$errorMessage          = $magewire->errorMessage;
$isLoggedIn            = $magewire->isLoggedIn;
$billingSameAsShipping = $magewire->billingSameAsShipping;
$countryId             = $magewire->countryId;
$billingCountryId      = $magewire->billingCountryId;
$regionId              = $magewire->regionId;
$region                = $magewire->region;
$billingRegionId       = $magewire->billingRegionId;
$billingRegion         = $magewire->billingRegion;

$savedAddresses          = $magewire->getSavedAddresses();
$countryOptions          = $magewire->getCountryOptions();
$regions                 = $magewire->getRegionsForCountry($countryId);
$isRegionRequired        = $magewire->isRegionRequired($countryId);
$billingRegions          = $magewire->getRegionsForCountry($billingCountryId);
$isBillingRegionRequired = $magewire->isRegionRequired($billingCountryId);
$postcodePatterns        = $magewire->getPostcodePatterns();
$postcodePatternsJson    = json_encode($postcodePatterns, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
$phoneFormatsJson        = json_encode($magewire->getPhoneFormats(), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);

$buildPostcodeXData = function (string $valueProp, string $countryProp) use ($postcodePatternsJson, $magewire) {
    $value   = json_encode((string) ($magewire->$valueProp ?? ''), JSON_UNESCAPED_UNICODE);
    $fmt     = json_encode((string) __('Please use the format: %1'), JSON_UNESCAPED_UNICODE);
    $invalid = json_encode((string) __('Please check the postcode format.'), JSON_UNESCAPED_UNICODE);
    return '{'
        . "patterns:$postcodePatternsJson,"
        . "value:$value,"
        . "msgFormat:$fmt,"
        . "msgInvalid:$invalid,"
        . 'get err(){'
            . "const v=(this.value||'').trim();"
            . "if(!v)return'';"
            . "const e=this.patterns[this.\$wire.$countryProp];"
            . "if(!e||!e.patterns||!e.patterns.length)return'';"
            . 'if(e.patterns.some(p=>new RegExp(p.pattern).test(v)))return\'\';'
            . "const ex=e.patterns[0].example||'';"
            . "return ex?this.msgFormat.replace('%1',ex):this.msgInvalid;"
        . '}'
    . '}';
};
$postcodeXData        = $buildPostcodeXData('postcode', 'countryId');
$billingPostcodeXData = $buildPostcodeXData('billingPostcode', 'billingCountryId');
?>

<div>

    <?php if ($errorMessage): ?>
    <div role="alert" class="checkout-error mb-4">
        <?= $escaper->escapeHtml($errorMessage) ?>
    </div>
    <?php endif ?>

    <?php if (!$isLoggedIn): ?>
    <div class="checkout-tabs">
        <span class="is-active"><?= $escaper->escapeHtml(__('Guest checkout')) ?></span>
        <a href="<?= $escaper->escapeUrl($block->getUrl('customer/account/login', ['referer' => base64_encode($block->getUrl('checkout'))])) ?>">
            <?= $escaper->escapeHtml(__('Sign in')) ?>
        </a>
    </div>
    <?php endif ?>

    <?php
    if (!empty($savedAddresses)) {
        $savedAddressesTemplate = $block->getTemplateFile('Ethelserth_Checkout::checkout/address/saved-addresses.phtml');
        if ($savedAddressesTemplate) include $savedAddressesTemplate;
    }
    ?>

    <form wire:submit.prevent="saveAddress" novalidate>

        <?php
        $formTemplate = $block->getTemplateFile('Ethelserth_Checkout::checkout/address/form.phtml');
        if ($formTemplate) include $formTemplate;
        ?>

        <?php
        $billingTemplate = $block->getTemplateFile('Ethelserth_Checkout::checkout/address/billing-toggle.phtml');
        if ($billingTemplate) include $billingTemplate;
        ?>

        <div class="checkout-submit pt-4 border-t border-gray-100 mt-5">
            <button type="submit" class="checkout-btn" wire:loading.attr="disabled">
                <span wire:loading.remove><?= $escaper->escapeHtml(__('Continue to shipping')) ?></span>
                <span wire:loading style="display:none" class="inline-flex items-center gap-2">
                    <svg class="animate-spin" width="14" height="14" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                    </svg>
                    <?= $escaper->escapeHtml(__('Saving…')) ?>
                </span>
            </button>
            <a href="<?= $escaper->escapeUrl($block->getUrl('checkout/cart')) ?>" class="checkout-link-muted ml-4">
                <?= $escaper->escapeHtml(__('Return to cart')) ?>
            </a>
        </div>

    </form>

</div>
