<?php
/**
 * Payment step orchestrator.
 *
 * Renders:
 *   1. Optional per-step express rail (PSP modules can target this)
 *   2. Method list (radio cards via method-list.phtml)
 *   3. Place-order CTA with the live grand total inline
 *   4. Compliance hint with a lock glyph
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Ethelserth\Checkout\Magewire\Step\Payment $magewire
 */
declare(strict_types=1);

$methods        = $magewire->methods;
$selectedMethod = $magewire->selectedMethod;
$placing        = $magewire->placing;
$grandTotal     = $magewire->getGrandTotalFormatted();
$jsAssets       = $magewire->jsAssets ?? [];
?>

<div>

    <?php /* Per-step express rail injection point — used by PSP modules
            that prefer to render their wallet button inside the payment
            step rather than at the top of the page. */ ?>
    <?= $block->getChildHtml('checkout.express.rail.payment') ?>

    <?php /* Method list */ ?>
    <?php include __DIR__ . '/../payment/method-list.phtml' ?>

    <?php /* Lazy-load JS assets when an adapter that needs them is selected.
            Renders nothing for offline methods. */ ?>
    <?php if (!empty($jsAssets)): ?>
        <?php foreach ($jsAssets as $asset): ?>
            <script src="<?= $escaper->escapeUrl($asset) ?>" defer></script>
        <?php endforeach ?>
    <?php endif ?>

    <div class="checkout-payment-cta">
        <button type="button"
                wire:click="placeOrder"
                wire:loading.attr="disabled"
                wire:target="placeOrder"
                <?= ($selectedMethod === '' || $placing) ? 'disabled' : '' ?>
                class="checkout-place-order">

            <span class="checkout-place-order-label" wire:loading.remove wire:target="placeOrder">
                <?= $escaper->escapeHtml(__('Place order')) ?>
            </span>
            <span class="checkout-place-order-label" wire:loading wire:target="placeOrder" style="display:none">
                <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg"
                     width="16" height="16" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor"
                          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
                <?= $escaper->escapeHtml(__('Placing order…')) ?>
            </span>

            <span class="checkout-place-order-divider" aria-hidden="true"></span>
            <span class="checkout-place-order-total"><?= $escaper->escapeHtml($grandTotal) ?></span>
        </button>

        <p class="checkout-place-order-hint">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor"
                 stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            <span>
                <?= $escaper->escapeHtml(__('By placing your order you agree to our')) ?>
                <a href="<?= $escaper->escapeUrl($block->getUrl('terms')) ?>"
                   class="underline ml-0.5"><?= $escaper->escapeHtml(__('terms')) ?></a>.
            </span>
        </p>
    </div>

</div>
