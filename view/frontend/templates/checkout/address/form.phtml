<?php
/**
 * Address form fields — rendered via include from step/address.phtml.
 * All variables listed below are populated in step/address.phtml and
 * are in scope because include() shares the enclosing PHP scope.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Ethelserth\Checkout\Magewire\Step\Address $magewire
 * @var \Ethelserth\Checkout\Model\Address\FieldConfig $fieldConfig
 * @var array  $countryOptions
 * @var array  $regions
 * @var string $countryId
 * @var string $regionId
 * @var bool   $isRegionRequired
 * @var string $postcodeXData       Alpine x-data JSON for shipping postcode live-validation
 * @var string $phoneFormatsJson    Per-country phone example digits (JSON)
 */
declare(strict_types=1);

$streetLines = $fieldConfig->getStreetLines();
?>

<div class="mb-3">
    <label for="checkout-email" class="checkout-label">
        <?= $escaper->escapeHtml(__('Email address')) ?><span class="req">*</span>
    </label>
    <div class="checkout-email-wrap">
        <input type="email" id="checkout-email" name="email"
               wire:model.defer="email"
               @blur="$wire.checkEmail"
               autocomplete="email" inputmode="email" required
               class="checkout-input checkout-email-input"/>
        <?php /* Inline check indicator. Three states stack on top of each
                other in the same `right: 0.75rem` slot, only one ever
                visible at a time:
                 - spinner   while the wire:checkEmail round-trip is in flight
                 - key glyph after a check that returned "account exists"
                 - check     after a check that returned "no account" (subtle reassurance, only when emailChecked=true)
                Renders nothing for logged-in shoppers. */ ?>
        <?php if (!$magewire->isLoggedIn): ?>
        <span class="checkout-email-indicator" aria-hidden="true">
            <svg wire:loading wire:target="checkEmail"
                 style="display:none"
                 class="checkout-email-spinner animate-spin"
                 width="16" height="16" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            <svg wire:loading.remove wire:target="checkEmail"
                 x-show="$wire.emailChecked && $wire.emailHasAccount"
                 x-cloak
                 class="checkout-email-icon checkout-email-icon--key"
                 width="16" height="16" fill="none" stroke="currentColor"
                 stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M15 7a4 4 0 110 8 4 4 0 010-8zm-4 4l-7 7v3h3l1-1v-2h2v-2h2l-1-5z"/>
            </svg>
            <svg wire:loading.remove wire:target="checkEmail"
                 x-show="$wire.emailChecked && !$wire.emailHasAccount && ($wire.email||'').length>0"
                 x-cloak
                 class="checkout-email-icon checkout-email-icon--ok"
                 width="16" height="16" fill="none" stroke="currentColor"
                 stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
        </span>
        <?php endif ?>
    </div>

    <?php /* Inline sign-in block. Reveals when checkEmail says
            "account exists." Filling the password tries to authenticate
            on next saveAddress; leaving it blank lets the shopper
            continue as a guest with this email — Luma parity. */ ?>
    <?php if (!$magewire->isLoggedIn): ?>
    <div class="checkout-signin-block"
         x-show="$wire.emailHasAccount"
         x-cloak
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0">
        <p class="checkout-signin-hint">
            <?= $escaper->escapeHtml(__('Looks like you already have an account.')) ?>
            <?= $escaper->escapeHtml(__('Enter your password and sign in, or just continue below to check out as a guest.')) ?>
        </p>
        <label for="checkout-password" class="checkout-label">
            <?= $escaper->escapeHtml(__('Password')) ?>
        </label>
        <input type="password" id="checkout-password" name="password"
               wire:model.defer="password"
               wire:keydown.enter.prevent="signIn"
               autocomplete="current-password"
               class="checkout-input"/>
        <?php if ($magewire->passwordError): ?>
        <p class="checkout-field-error" role="alert">
            <?= $escaper->escapeHtml($magewire->passwordError) ?>
        </p>
        <?php endif ?>
        <div class="checkout-signin-actions">
            <button type="button"
                    wire:click="signIn"
                    wire:loading.attr="disabled"
                    wire:target="signIn"
                    class="checkout-btn checkout-signin-btn">
                <span wire:loading.remove wire:target="signIn">
                    <?= $escaper->escapeHtml(__('Sign in')) ?>
                </span>
                <span wire:loading wire:target="signIn" style="display:none" class="inline-flex items-center gap-2">
                    <svg class="animate-spin" width="14" height="14" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                    </svg>
                    <?= $escaper->escapeHtml(__('Signing in…')) ?>
                </span>
            </button>
            <a href="<?= $escaper->escapeUrl($block->getUrl('customer/account/forgotpassword')) ?>"
               class="checkout-link-muted">
                <?= $escaper->escapeHtml(__('Forgot your password?')) ?>
            </a>
        </div>
    </div>
    <?php endif ?>
</div>

<div class="checkout-divider"><?= $escaper->escapeHtml(__('Delivery address')) ?></div>

<?php if ($fieldConfig->isFieldVisible('prefix')): ?>
<div class="mb-3">
    <label for="checkout-prefix" class="checkout-label">
        <?= $escaper->escapeHtml(__('Prefix')) ?>
        <?php if ($fieldConfig->isFieldRequired('prefix')): ?><span class="req">*</span><?php endif ?>
    </label>
    <input type="text" id="checkout-prefix" name="prefix"
           wire:model.defer="prefix"
           autocomplete="honorific-prefix"
           <?= $fieldConfig->isFieldRequired('prefix') ? 'required' : '' ?>
           class="checkout-input"/>
</div>
<?php endif ?>

<?php if ($fieldConfig->isPostcodeLookupEnabled()):
    $postcodeLookupTemplate = $block->getTemplateFile('Ethelserth_Checkout::checkout/address/postcode-lookup.phtml');
    if ($postcodeLookupTemplate) include $postcodeLookupTemplate;
endif ?>

<!-- First / Middle / Last name -->
<div class="grid <?= $fieldConfig->isFieldVisible('middlename') ? 'grid-cols-3' : 'grid-cols-2' ?> gap-3 mb-3">
    <div>
        <label for="checkout-firstname" class="checkout-label">
            <?= $escaper->escapeHtml(__('First name')) ?><span class="req">*</span>
        </label>
        <input type="text" id="checkout-firstname" name="firstname"
