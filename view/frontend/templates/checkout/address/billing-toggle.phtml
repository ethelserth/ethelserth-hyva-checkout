<?php
/**
 * Billing address toggle and separate billing form.
 * Rendered via include from step/address.phtml.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Ethelserth\Checkout\Magewire\Step\Address $magewire
 * @var \Ethelserth\Checkout\Model\Address\FieldConfig $fieldConfig
 * @var array  $countryOptions
 * @var array  $billingRegions
 * @var string $billingCountryId
 * @var string $billingRegionId
 * @var bool   $isBillingRegionRequired
 * @var string $billingPostcodeXData Alpine x-data JSON for billing postcode live-validation
 * @var string $phoneFormatsJson     Per-country phone example digits (JSON)
 */
declare(strict_types=1);
?>

<label for="checkout-billing-same" class="checkout-choice mb-4">
    <input type="checkbox"
           id="checkout-billing-same"
           wire:model="billingSameAsShipping"
           class="mt-0.5"/>
    <div>
        <p class="checkout-choice-title">
            <?= $escaper->escapeHtml(__('Billing address same as delivery address')) ?>
        </p>
        <p class="checkout-choice-sub">
            <?= $escaper->escapeHtml(__('Uncheck to enter a different billing address')) ?>
        </p>
    </div>
</label>

<div x-show="!$wire.billingSameAsShipping"
     x-cloak
     style="display:none"
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0 -translate-y-1"
     x-transition:enter-end="opacity-100 translate-y-0"
     class="mb-4 p-4 rounded-md border border-gray-200 space-y-3">

    <div class="checkout-divider"><?= $escaper->escapeHtml(__('Billing address')) ?></div>

    <div class="grid grid-cols-2 gap-3">
        <div>
            <label class="checkout-label">
                <?= $escaper->escapeHtml(__('First name')) ?><span class="req">*</span>
            </label>
            <input type="text"
                   wire:model.defer="billingFirstname"
                   autocomplete="billing given-name"
                   class="checkout-input"/>
        </div>
        <div>
            <label class="checkout-label">
                <?= $escaper->escapeHtml(__('Last name')) ?><span class="req">*</span>
            </label>
            <input type="text"
                   wire:model.defer="billingLastname"
                   autocomplete="billing family-name"
                   class="checkout-input"/>
        </div>
    </div>

    <?php if ($fieldConfig->isFieldVisible('company')): ?>
    <div>
        <label class="checkout-label">
            <?= $escaper->escapeHtml(__('Company')) ?>
            <span class="opt">(<?= $escaper->escapeHtml(__('optional')) ?>)</span>
        </label>
        <input type="text"
               wire:model.defer="billingCompany"
               autocomplete="billing organization"
               class="checkout-input"/>
    </div>
    <?php endif ?>

    <div>
        <label class="checkout-label">
            <?= $escaper->escapeHtml(__('Street')) ?><span class="req">*</span>
        </label>
        <input type="text"
               wire:model.defer="billingStreet1"
               autocomplete="billing address-line1"
               class="checkout-input mb-2"/>
        <input type="text"
               wire:model.defer="billingStreet2"
               autocomplete="billing address-line2"
               placeholder="<?= $escaper->escapeHtmlAttr(__('Addition (optional)')) ?>"
               class="checkout-input"/>
    </div>

    <div class="grid grid-cols-2 gap-3">
        <div>
            <label class="checkout-label">
                <?= $escaper->escapeHtml(__('City')) ?><span class="req">*</span>
            </label>
            <input type="text"
                   wire:model.defer="billingCity"
                   autocomplete="billing address-level2"
                   class="checkout-input"/>
        </div>
        <div>
            <label class="checkout-label"><?= $escaper->escapeHtml(__('Country')) ?></label>
            <select wire:model="billingCountryId"
                    autocomplete="billing country"
                    class="checkout-input">
                <?php foreach ($countryOptions as $opt):
                    if (empty($opt['value'])) continue; ?>
                <option value="<?= $escaper->escapeHtmlAttr($opt['value']) ?>"
                        <?= $opt['value'] === $billingCountryId ? 'selected' : '' ?>>
                    <?= $escaper->escapeHtml($opt['label']) ?>
                </option>
                <?php endforeach ?>
            </select>
        </div>
    </div>

    <?php if (!empty($billingRegions)): ?>
    <div class="grid grid-cols-2 gap-3">
        <div x-data="<?= $escaper->escapeHtmlAttr($billingPostcodeXData) ?>">
            <label class="checkout-label">
                <?= $escaper->escapeHtml(__('Postcode')) ?><span class="req">*</span>
            </label>
            <input type="text"
                   x-model="value"
                   wire:model.defer="billingPostcode"
                   autocomplete="billing postal-code"
                   class="checkout-input"/>
            <p class="checkout-field-error" x-show="err" x-text="err" x-cloak></p>
        </div>
        <div>
            <label class="checkout-label">
                <?= $escaper->escapeHtml(__('State / Province')) ?>
                <?php if ($isBillingRegionRequired): ?><span class="req">*</span><?php endif ?>
            </label>
            <select wire:model.defer="billingRegionId"
                    <?= $isBillingRegionRequired ? 'required' : '' ?>
                    class="checkout-input">
                <option value=""><?= $escaper->escapeHtml(__('-- Please select --')) ?></option>
                <?php foreach ($billingRegions as $r): ?>
                <option value="<?= $escaper->escapeHtmlAttr($r['value']) ?>"
                        <?= (string)$r['value'] === $billingRegionId ? 'selected' : '' ?>>
                    <?= $escaper->escapeHtml($r['label']) ?>
                </option>
                <?php endforeach ?>
            </select>
        </div>
    </div>
    <?php else: ?>
    <div x-data="<?= $escaper->escapeHtmlAttr($billingPostcodeXData) ?>">
        <label class="checkout-label">
            <?= $escaper->escapeHtml(__('Postcode')) ?><span class="req">*</span>
        </label>
        <input type="text"
               x-model="value"
               wire:model.defer="billingPostcode"
               autocomplete="billing postal-code"
               class="checkout-input"/>
        <p class="checkout-field-error" x-show="err" x-text="err" x-cloak></p>
    </div>
    <?php endif ?>

    <?php if ($fieldConfig->isFieldVisible('telephone')): ?>
    <div x-data='{ formats: <?= /* @noEscape */ $phoneFormatsJson ?>, get example() { return this.formats[this.$wire.billingCountryId] || ""; } }'>
        <label class="checkout-label"><?= $escaper->escapeHtml(__('Phone')) ?></label>
        <input type="tel"
               wire:model.defer="billingTelephone"
               @input="$event.target.value = $event.target.value.replace(/\D+/g, '')"
               :placeholder="example"
               autocomplete="billing tel"
               inputmode="numeric" pattern="[0-9]*"
               class="checkout-input"/>
        <p class="checkout-hint"><?= $escaper->escapeHtml(__('Digits only.')) ?></p>
    </div>
    <?php endif ?>

</div>
