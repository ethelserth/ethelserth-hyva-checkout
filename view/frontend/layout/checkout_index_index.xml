<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <update handle="hyva_reset_styles"/>
    <body>
        <referenceBlock name="fallback.module.missing" remove="true"/>
        <referenceContainer name="content">
            <block class="Ethelserth\Checkout\Block\Checkout"
                   name="checkout.root"
                   template="Ethelserth_Checkout::checkout/checkout.phtml"
                   cacheable="false">

                <!-- Express rail: PSP modules inject here (Revolut Fast Checkout, etc.) -->
                <container name="checkout.express.rail"
                           htmlTag="div"
                           htmlId="checkout-express-rail"
                           htmlClass="checkout-express-rail"/>

                <!-- Step blocks — must be defined here with magewire argument for Magewire wiring -->
                <block class="Magento\Framework\View\Element\Template"
                       name="checkout.step.address"
                       template="Ethelserth_Checkout::checkout/step/address.phtml">
                    <arguments>
                        <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Step\Address</argument>
                        <argument name="field_config" xsi:type="object">Ethelserth\Checkout\Model\Address\FieldConfig</argument>
                    </arguments>
                </block>

                <block class="Magento\Framework\View\Element\Template"
                       name="checkout.step.shipping"
                       template="Ethelserth_Checkout::checkout/step/shipping.phtml">
                    <arguments>
                        <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Step\Shipping</argument>
                    </arguments>
                </block>

                <block class="Magento\Framework\View\Element\Template"
                       name="checkout.step.payment"
                       template="Ethelserth_Checkout::checkout/step/payment.phtml">
                    <arguments>
                        <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Step\Payment</argument>
                    </arguments>
                </block>

                <!-- Order summary: items + coupon + totals.
                     Each child is its own Magewire mount so it can re-render
                     on its own event channel without dragging the others. -->
                <block class="Magento\Framework\View\Element\Template"
                       name="checkout.summary"
                       template="Ethelserth_Checkout::checkout/summary/root.phtml">

                    <block class="Magento\Framework\View\Element\Template"
                           name="checkout.summary.items"
                           template="Ethelserth_Checkout::checkout/summary/items.phtml">
                        <arguments>
                            <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Summary\Items</argument>
                        </arguments>
                    </block>

                    <block class="Magento\Framework\View\Element\Template"
                           name="checkout.summary.coupon"
                           template="Ethelserth_Checkout::checkout/summary/coupon.phtml">
                        <arguments>
                            <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Summary\Coupon</argument>
                        </arguments>
                    </block>

                    <block class="Magento\Framework\View\Element\Template"
                           name="checkout.summary.totals"
                           template="Ethelserth_Checkout::checkout/summary/totals.phtml">
                        <arguments>
                            <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Summary\Totals</argument>
                        </arguments>
                    </block>

                </block>

            </block>
        </referenceContainer>
    </body>
</page>
