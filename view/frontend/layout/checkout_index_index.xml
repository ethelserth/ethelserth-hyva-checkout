<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <update handle="hyva_reset_styles"/>
    <body>
        <referenceBlock name="fallback.module.missing" remove="true"/>
        <referenceContainer name="content">
            <block class="Ethelserth\Checkout\Block\Checkout"
                   name="checkout.root"
                   template="Ethelserth_Checkout::checkout/checkout.phtml"
                   cacheable="false">

                <!-- Express rail: PSP modules inject here (Revolut Fast Checkout, etc.) -->
                <container name="checkout.express.rail"
                           htmlTag="div"
                           htmlId="checkout-express-rail"
                           htmlClass="checkout-express-rail"/>

                <!-- Step blocks — must be defined here with magewire argument for Magewire wiring -->
                <block class="Magento\Framework\View\Element\Template"
                       name="checkout.step.address"
                       template="Ethelserth_Checkout::checkout/step/address.phtml">
                    <arguments>
                        <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Step\Address</argument>
                    </arguments>
                </block>

                <block class="Magento\Framework\View\Element\Template"
                       name="checkout.step.shipping"
                       template="Ethelserth_Checkout::checkout/step/shipping.phtml">
                    <arguments>
                        <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Step\Shipping</argument>
                    </arguments>
                </block>

                <block class="Magento\Framework\View\Element\Template"
                       name="checkout.step.payment"
                       template="Ethelserth_Checkout::checkout/step/payment.phtml">
                    <arguments>
                        <argument name="magewire" xsi:type="object">Ethelserth\Checkout\Magewire\Step\Payment</argument>
                    </arguments>
                </block>

            </block>
        </referenceContainer>
    </body>
</page>
