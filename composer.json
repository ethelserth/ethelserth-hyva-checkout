{
    "name": "ethelserth/hyva-checkout",
    "description": "Ethelserth Hyva + Magewire checkout — replaces Magento's native Luma checkout entirely",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=102.0",
        "magento/module-checkout": "*",
        "magento/module-quote": "*",
        "magento/module-customer": "*",
        "hyva-themes/magento2-theme-module": "^1.3",
        "hyva-themes/magento2-default-theme": "^1.3",
        "magewirephp/magewire": "^1.4"
    },
    "autoload": {
        "files": ["registration.php"],
        "psr-4": {
            "Ethelserth\\Checkout\\": ""
        }
    },
    "extra": {
        "magento-module-name": "Ethelserth_Checkout"
    }
}
