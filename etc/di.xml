<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Step config reader: scans all modules for Config/checkout_steps.xml -->
    <type name="Ethelserth\Checkout\Model\Step\Config">
        <arguments>
            <argument name="configFile" xsi:type="string">checkout_steps.xml</argument>
        </arguments>
    </type>

    <!-- Payment adapter registry. PSP modules append to the `adapters` array
         from their own etc/frontend/di.xml, e.g.:

           <type name="Ethelserth\Checkout\Model\Payment\MethodPool">
               <arguments>
                   <argument name="adapters" xsi:type="array">
                       <item name="viva_smart" xsi:type="object">Ethelserth\CheckoutViva\Adapter\SmartCheckout</item>
                   </argument>
               </arguments>
           </type>
    -->
    <type name="Ethelserth\Checkout\Model\Payment\MethodPool">
        <arguments>
            <argument name="adapters" xsi:type="array"/>
        </arguments>
    </type>

    <!-- Order comments — wire the `order_comments` column through the
         `order_comments` extension attribute on Cart + Order so REST
         consumers can read/write the value via the standard endpoints.
         All four plugin methods sanitize as defense in depth. -->
    <type name="Magento\Quote\Api\CartRepositoryInterface">
        <plugin name="ethelserth_checkout_cart_order_comments"
                type="Ethelserth\Checkout\Plugin\Quote\CartExtensionPlugin"
                sortOrder="10"/>
    </type>
    <type name="Magento\Sales\Api\OrderRepositoryInterface">
        <plugin name="ethelserth_checkout_order_order_comments"
                type="Ethelserth\Checkout\Plugin\Sales\OrderExtensionPlugin"
                sortOrder="10"/>
    </type>

</config>
