<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <ethelserth_checkout>
            <address_lookup>
                <enabled>0</enabled>
            </address_lookup>
            <newsletter>
                <enabled>1</enabled>
                <label>Subscribe to our newsletter</label>
                <notice>By subscribing you agree to receive marketing emails from us. We process your email solely to send these messages and you can unsubscribe at any time. See our privacy policy for details.</notice>
            </newsletter>
            <order_comments>
                <enabled>0</enabled>
                <placement>payment</placement>
                <label>Order notes (optional)</label>
                <placeholder>Delivery instructions, gift message, scheduling…</placeholder>
            </order_comments>
        </ethelserth_checkout>
    </default>
</config>
